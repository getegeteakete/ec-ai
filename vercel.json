{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "crons": [
    {
      "path": "/api/btob-daily",
      "schedule": "0 0 * * 1-5"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/public/(.*)", "dest": "/public/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
