# ============================================================
# Vercel 環境変数設定
# Vercel Dashboard → プロジェクト → Settings → Environment Variables
# ============================================================

# KOMOJU 非公開鍵
# KOMOJUダッシュボード → 設定 → ID/APIキー → 非公開鍵（目のアイコンで表示）
KOMOJU_SECRET_KEY=（KOMOJUダッシュボードの非公開鍵を貼り付け）

# KOMOJU Webhookシークレットトークン
# KOMOJUダッシュボード → 設定 → ウェブフックシークレットトークン
KOMOJU_WEBHOOK_TOKEN=（KOMOJUダッシュボードのウェブフックトークンを貼り付け）
